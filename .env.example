# Copy to `.env` and adjust. Docker Compose reads `.env` from the project root for variable substitution.
# Never commit `.env` (it is gitignored).

# --- SonarQube scanner (only when using `docker compose --profile sonar`) ---
# Create a token in SonarQube: User > My Account > Security > Generate Tokens
SONAR_TOKEN=

# Optional: override the URL the scanner uses to reach SonarQube inside Docker (default matches compose service name)
# SONAR_HOST_URL=http://sonarqube:9000

# If this repository ever contained a committed token, revoke it in SonarQube and generate a new token here.
