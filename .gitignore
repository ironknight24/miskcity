# Ignore directories managed by Composer
/vendor/
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/libraries/
/drush/Commands/contrib/

# Ignore Drupal's site-specific files
/web/sites/*/settings.php
/web/sites/*/example.settings.docker.php
/web/sites/*/settings.local.php
/web/sites/*/services.yml
/web/sites/*/services.local.yml
/web/sites/*/files/
/web/sites/*/private/

# Ignore simpletest directory
/web/sites/simpletest/

# Ignore development files
.env
.env.local
.env.*.local

# IDE files
.idea/
.vscode/

# OS files
.DS_Store
Thumbs.db

# Local SQL dumps (large; do not commit)
/drupal.sql
/drupal_import.sql

# Other common excludes
node_modules/
.sass-cache/

# PHPUnit / Sonar coverage artifacts (directory tracked via coverage/.gitkeep)
/coverage/*
!/coverage/.gitkeep
*.sql
scripts/