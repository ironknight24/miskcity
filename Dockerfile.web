# Use official Drupal 11 PHP-FPM image
FROM drupal:11-php8.4-fpm

# Set working directory
WORKDIR /opt/drupal/web

# Install system dependencies and PHP extensions required for Drupal
RUN apt-get update && apt-get install -y \
    git \
    unzip \
    libjpeg-dev \
    libpng-dev \
    libwebp-dev \
    libavif-dev \
    libfreetype6-dev \
    libicu-dev \
    libxml2-dev \
    libgmp-dev \
    zip \
    curl \
    && docker-php-ext-configure gd --with-jpeg --with-webp --with-avif --with-freetype \
    && docker-php-ext-install -j$(nproc) bcmath gd gmp intl pdo_mysql xml \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Install Composer
RUN curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer

# Xdebug: install but do NOT enable globally — it slows every request and drush (even with mode=off).
# Use /usr/local/bin/php-xdebug for PHPUnit coverage (see Readme).
RUN pecl install xdebug \
    && XDEBUG_SO=$(find /usr/local/lib/php/extensions -name xdebug.so -print -quit) \
    && printf '#!/bin/sh\nexec php -d zend_extension=%s "$@"\n' "$XDEBUG_SO" > /usr/local/bin/php-xdebug \
    && chmod +x /usr/local/bin/php-xdebug

# PhpRedis for contrib redis module (Docker Compose service `redis` when REDIS_HOST is set).
RUN pecl install redis \
    && docker-php-ext-enable redis

# OPcache + realpath cache (faster bootstrap after cache clears, fewer stat() calls).
COPY docker/php/99-opcache.ini /usr/local/etc/php/conf.d/99-opcache.ini

# Drupal + Drush CLI need more than default 128M (avoids memory exhausted on cache rebuilds).
RUN echo "memory_limit = 512M" > /usr/local/etc/php/conf.d/zz-drupal-memory.ini

# Add vendor/bin to PATH
ENV PATH="/opt/drupal/vendor/bin:${PATH}"

# Image-only ownership for paths before bind mounts; the host project is mounted at /opt/drupal at runtime.
RUN chown -R www-data:www-data /opt/drupal/web /opt/drupal/vendor