function court_booking_update_9020(): void {
  \Drupal::moduleHandler()->loadInclude('court_booking', 'inc', 'court_booking.locale_register');
  _court_booking_register_js_interface_strings();
}

/**
 * Migrate variation_pricing_windows to variation_pricing_rules; clear legacy key.
 */
function court_booking_update_9021(): void {
  $editable = \Drupal::configFactory()->getEditable('court_booking.settings');
  if ($editable->get('variation_pricing_rules') === NULL) {
    $editable->set('variation_pricing_rules', []);
  }
  $legacy = $editable->get('variation_pricing_windows');
  if (!is_array($legacy) || $legacy === []) {
    $editable->save();

    return;
  }
  $converted = \Drupal\court_booking\CourtBookingPricingRulesEngine::convertLegacyWindowsToRules($legacy);
  $editable->set('variation_pricing_rules', $converted);
  $editable->set('variation_pricing_windows', []);
  $editable->save();
  \Drupal::logger('court_booking')->notice('court_booking_update_9021: migrated @n variation pricing window group(s) to variation_pricing_rules.', [
    '@n' => (string) count($converted),
  ]);
}

