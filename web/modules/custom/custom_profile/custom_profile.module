<?php

/**
 * @file
 * Hooks and theme definitions for the Custom Profile Page module.
 *
 * This module provides the citizen-facing "My Account" dashboard, which allows
 * authenticated users to:
 *  - View and edit their personal profile (name, gender, DOB, address).
 *  - Upload or remove their profile picture.
 *  - Add and manage family members via an external citizen-app API.
 *  - Change their IDAM-managed password.
 *  - Add, edit, and delete saved addresses (stored as Drupal nodes).
 *  - Browse their service-request history and inspect individual request details.
 */

/**
 * Implements hook_theme().
 *
 * Registers all Twig template definitions used by this module. Each entry maps
 * a theme hook name to a template file inside the module's /templates directory
 * and declares the variables that will be available inside that template.
 */
function custom_profile_theme($existing, $type, $theme, $path)
{
  $module_path = \Drupal::service('extension.list.module')->getPath('custom_profile') . '/templates';

  return [
    'family_members_block' => [
      'variables' => ['members' => []],
      'template' => 'family-members-block',
      'path' => $module_path,
    ],
    'custom_profile' => [
      'variables' => [
        'form' => NULL,
        'profile_picture_form' => NULL,
        'family_form' => NULL,
        'my_profile_title' => NULL,
      ],
      'template' => 'custom_profile',
      'path' => $module_path,
    ],
    'add-family-member' => [
      'render element' => 'form',
      'template' => 'add-family-member',
      'path' => \Drupal::service('extension.list.module')->getPath('custom_profile') . '/templates',
    ],
    'success-family-member' => [
      'render element' => 'elements',
      'template' => 'success-family-member',
    ],
    'failed-family-member' => [
      'render element' => 'elements',
      'template' => 'failed-family-member',
    ],
    'change-password' => [
      'render element' => 'form',
      'template' => 'change-password',
      'path' => \Drupal::service('extension.list.module')->getPath('custom_profile') . '/templates',
    ],
    'add_address_form' => [
      'render element' => 'form',
      'template' => 'add-address-form',
      'path' => \Drupal::service('extension.list.module')->getPath('custom_profile') . '/templates',
    ],
    'my_services_page' => [
      'variables' => [
        'data' => [],
        'total_count' => 0,
        'current_page' => 1,
        'items_per_page' => 10,
        'search' => '',
      ],
      'template' => 'my-services-page',
      'path' => $module_path,
    ],
    'request_details_page' => [
      'variables' => ['data' => []],
      'template' => 'request-details-page',
      'path' => $module_path,
    ],

  ];
}


/**
 * Implements hook_preprocess_page().
 *
 * On the My Account page, loads the body value from the first published
 * "basic" block content entity and exposes it as $my_profile_title so the
 * page template can display a configurable section heading.
 */
function custom_profile_preprocess_page(array &$variables)
{
  if (\Drupal::routeMatch()->getRouteName() === 'custom_profile.my_account') {

    $block_storage = \Drupal::entityTypeManager()->getStorage('block_content');
    $blocks = $block_storage->loadByProperties([
      'type' => 'basic',
      'status' => 1,
    ]);
    $block = reset($blocks);
    if ($block && $block->hasField('body')) {
      $variables['my_profile_title'] = $block->get('body')->value;
    }
  }
}

/**
 * Implements hook_form_alter().
 *
 * Reserved for future form-specific overrides (e.g. AI CKEditor dialog tweaks).
 */
function custom_profile_form_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id)
{
}

/**
 * Implements hook_page_attachments().
 *
 * Attaches the AI media modal fix library only on Gin-themed admin routes,
 * keeping the asset out of front-end pages entirely.
 */
function custom_profile_page_attachments(array &$attachments) {
  $theme = \Drupal::theme()->getActiveTheme()->getName();

  if ($theme === 'gin' && \Drupal::service('router.admin_context')->isAdminRoute()) {
    $attachments['#attached']['library'][] = 'custom_profile/ai_media_modal_fix';
  }
}