function custom_profile_page_attachments(array &$attachments) {
  $theme = \Drupal::theme()->getActiveTheme()->getName();

  if ($theme === 'gin' && \Drupal::service('router.admin_context')->isAdminRoute()) {
    $attachments['#attached']['library'][] = 'custom_profile/ai_media_modal_fix';
  }
}