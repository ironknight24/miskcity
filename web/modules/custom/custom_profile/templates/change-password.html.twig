<div class="change-password-page min-h-screen bg-cover bg-center flex flex-col items-center justify-center" id="change-password-form-wrapper">

	<div class="change-password-page__inner flex flex-col mx-auto w-full max-w-md px-4">

		<!-- Back button (image wrapped in button for accessibility compliance) -->
		<div class="flex-shrink-0 mr-8 pb-6">
			<button type="button" aria-label="Go Back" onclick="window.location.href='my-account'" class="cursor-pointer w-10 h-10 xs:w-8 xs:h-8 p-0 bg-transparent border-0">
				<img src="themes/custom/engage_theme/images/Profile/white-arrow-left.svg" alt="Back" class="w-10 h-10 xs:w-8 xs:h-8 object-contain">
			</button>
		</div>

		<div class="change-password-card p-10 sm:p-12 bg-white shadow-lg rounded-2xl w-full mx-auto border border-gray-100" id="engage_form_input">

			<img class="change-password-card__logo" src="/modules/custom/custom_profile/images/Engage/normal_trinity_blue_4x_u16.png" alt="{{ 'Site logo'|t }}">

			<h2 class="change-password-card__title text-2xl sm:text-3xl font-bold text-[#1a1a1a] mb-2 text-left font-sans tracking-tight">{{ 'Change Password'|t }}</h2>

			<div class="change-password-card__subtitle mb-8">
				<p class="text-gray-500 text-sm sm:text-base leading-relaxed">{{ 'Please create a new password.'|t }}</p>
			</div>

			<!-- Old Password -->
			<div class="relative mb-4 change-password-field-row">
				{{ include('@engage_theme/components/form/field--floating-text.html.twig', { field: form.old_password }) }}
			</div>

			<!-- New Password -->
			<div class="relative mb-4 change-password-field-row change-password-field-row--with-tooltip">
				{{ include('@engage_theme/components/form/field--floating-text.html.twig', { field: form.new_password }) }}

				<div id="password-tooltip-new" class="change-password-card__tooltip absolute z-50 mt-2 left-0 invisible opacity-0 transition-opacity duration-300 ease-in-out bg-white border border-gray-200 p-4 rounded-xl shadow-md text-sm w-full max-w-md">
					<p class="font-semibold mb-2 text-sm text-gray-700">{{ 'Password must contain:'|t }}</p>
					<ul class="list-disc ml-5 space-y-1">
						<li id="rule-length-new" class="text-red-600">At least 8 characters</li>
						<li id="rule-uppercase-new" class="text-red-600">At least one uppercase letter</li>
						<li id="rule-lowercase-new" class="text-red-600">At least one lowercase letter</li>
						<li id="rule-number-new" class="text-red-600">At least one number</li>
						<li id="rule-special-new" class="text-red-600">At least one special character (@!$#%^&*)</li>
					</ul>
				</div>
			</div>

			<!-- Confirm Password -->
			<div class="relative mb-4 change-password-field-row change-password-field-row--with-tooltip">
				{{ include('@engage_theme/components/form/field--floating-text.html.twig', { field: form.confirm_password }) }}

				<div id="password-tooltip-confirm" class="change-password-card__tooltip absolute z-50 mt-2 left-0 invisible opacity-0 transition-opacity duration-300 ease-in-out bg-white border border-gray-200 p-4 rounded-xl shadow-md text-sm w-full max-w-md">
					<p class="font-semibold mb-2 text-sm text-gray-700">{{ 'Password must contain:'|t }}</p>
					<ul class="list-disc ml-5 space-y-1">
						<li id="rule-length-confirm" class="text-red-600">At least 8 characters</li>
						<li id="rule-uppercase-confirm" class="text-red-600">At least one uppercase letter</li>
						<li id="rule-lowercase-confirm" class="text-red-600">At least one lowercase letter</li>
						<li id="rule-number-confirm" class="text-red-600">At least one number</li>
						<li id="rule-special-confirm" class="text-red-600">At least one special character (@!$#%^&*)</li>
						<li id="passmatch">Passwords must match</li>
					</ul>
				</div>
			</div>

			<!-- Submit -->
			<div class="change-password-card__actions mt-8 w-full">
				<div class="w-full">{{ form.actions.submit }}</div>
			</div>
		</div>
	</div>

	{{ form.form_build_id }}
	{{ form.form_token }}
	{{ form.form_id }}
</div>
