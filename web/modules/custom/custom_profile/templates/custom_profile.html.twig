<div class="mx-auto max-w-screen-xl bg-white py-2 px-4">
	<div class="flex justify-center">
		<div class="container my-account-wrapper">
			<div
				class="flex justify-between items-center">
				<!-- Back Arrow Button -->
				<button type="button" aria-label="Go back" onclick="history.go(-1)" class="w-5 sm:w-7 p-0 bg-transparent border-none cursor-pointer" style="background:none; border:none;">
					<img src="themes/custom/engage_theme/images/Profile/reverse-arrow.svg" alt="Back Arrow" class="w-full h-auto object-contain"/>
				</button>
				<!-- Heading -->
				<h1 class="mt-8 md:mt-12 mb-8 md:mb-20 text-3xl sm:text-4xl md:text-5xl font-nevis" label-alias="la_my_profile">
					{{'My Profile'|t}}
				</h1>
				<div class="successOrFailure hidden absolute left-1/2 transform -translate-x-1/2 animate-fade-in-down">
					<div class="flex items-center gap-4 border shadow-xl rounded-xl px-6 py-4 bg-white text-center lg:text-left">
						<img src="" class="update-img w-16 h-16" alt="status icon">
						<p class="update-msg text-base font-medium text-gray-800"></p>
					</div>
				</div>

				<!-- Placeholder for symmetry -->
				<div class="w-5 sm:w-7"></div>
			</div>
			<div class="gap-4 md:flex md:mb-5">
				<div class="md:basis-[33%] mb-5">
					<h1 class="text-2xl text-[#404040] font-[nevis] font-bold mb-8 s:mb-5 xs:mb-5 translateLabel search_field" label-alias="la_personal_details">{{'Personal Details'|t}}</h1>
					<div class="container my-account-wrapper scroller max-w-4xl mx-auto border border-inherit border-2 rounded-md p-4 bg-white text-center lg:text-left gap-4 sm:mb-5 xs:mb-5">


						<div
							id="engage_form_input">
							{# Profile Picture Form #}
							<form method="post" accept-charset="UTF-8">
								{{ profile_picture_form.form_build_id }}
								{{ profile_picture_form.form_token }}
								{{ profile_picture_form.form_id }}

								<div class="avatar flex flex-col items-center relative">
									{{ profile_picture_form.image }}
									{{ profile_picture_form.user_id }}
									<div>
										{{ profile_picture_form.edit_label }}
										{{ profile_picture_form.upload_file }}
									</div>
									<div>
										{{ profile_picture_form.remove }}
									</div>
									{{ profile_picture_form.note }}
								</div>
							</form>

							{# Profile Details Form #}
							<form method="post" id="profile-form" accept-charset="UTF-8">
								{{ form.form_build_id }}
								{{ form.form_token }}
								{{ form.form_id }}

								<div class="grid gap-y-[15px]">
									{{ include('@engage_theme/components/form/field--floating-text.html.twig', {
                    				field: form.first_name
                				}) }}
									{{ include('@engage_theme/components/form/field--floating-text.html.twig', {
                    				field: form.last_name
                				}) }}
									{{ include('@engage_theme/components/form/field--floating-text.html.twig', {
                    				field: form.email
                				}) }}
									{{ include('@engage_theme/components/form/field--floating-text.html.twig', {
                    				field: form.mobile
                				}) }}
									{# {{ form.email }}
																																													{{ form.mobile }} #}
									{{ include('@engage_theme/components/form/field--floating-text.html.twig', {
                    				field: form.gender
                				}) }}
									{{ include('@engage_theme/components/form/field--floating-text.html.twig', {
                    				field: form.dob
                				}) }}

									{{ include('@engage_theme/components/form/field--floating-text.html.twig', {
                    				field: form.address
                				}) }}
									{# {{ form.dob }}
																																													{{ form.address }} #}
									{{ form.actions.submit }}
								</div>

							</form>
						</div>
					</div>
				</div>
				<div class="md:basis-[33%] mb-5">
					<h1 class="text-2xl text-[#404040] font-[nevis] font-bold mb-8 s:mb-5 xs:mb-5 translateLabel search_field" label-alias="la_family_details">{{'Family Details'|t}}</h1>
					<div class="container my-account-wrapper scroller border-inherit	border-2 rounded-lg p-4 bg-white text-center lg:text-start  s:mb-5 xs:mb-5">

						<div
							class="flex justify-between items-center gap-4">
							<!-- Add Family Member Section -->
							<div class="flex gap-3 items-center">
								<div class="border rounded-full p-3">
									<a href="./add-family-member">
										<img class="object-contain cursor-pointer" src="themes/custom/engage_theme/images/Profile/add-family.png" alt="add-family">
									</a>
								</div>
								<p class="add_family translateLabel search_field" label-alias="la_add_family_memebers">
									{{'Add Family Members'|t}}
								</p>
							</div>

							<!-- Toggle Delete Icon -->
							<div class="showDeleteIcons flex items-center gap-2">
								<div class="swap-off cursor-pointer">
									<img class="h-6 w-6" src="themes/custom/engage_theme/images/Profile/delete_all.png" alt="delete_icon">
								</div>
								<div class="swap-on hidden cursor-pointer">
									<img class="h-6 w-6" src="themes/custom/engage_theme/images/Profile/normal_clear.svg" alt="delete_icon">
								</div>
							</div>
						</div>

						<div class="border-t border-[#dedede] border-solid dottedBorder my-3"></div>
						{{ drupal_block('custom_profile_family_members_block')}}

					</div>

				</div>
				<div class="md:basis-[33%] mb-5">
					<h1 class="text-2xl text-[#404040] font-[nevis] font-bold mb-8 s:mb-5 xs:mb-5 translateLabel search_field" label-alias="la_my_account">My Account</h1>
					<div class="container my-account-wrapper scroller max-w-4xl mx-auto border border-inherit border-2 rounded-md p-5 bg-white
																																																																																																									            text-center lg:text-left grid grid-cols-1 gap-4
																																																																																																									            sm:mb-5 xs:mb-5">

						{{ drupal_menu("account-details")}}

					</div>
				</div>
			</div>
		</div>


		<div
			id="feedback_profile" tabindex="-1" aria-hidden="true" class=" hidden modal-thanks overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-auto max-h-full" style="background:#0000008a">
			<!-- Container for the profile-engage template -->
			<div
				class="relative client p-4 w-full max-w-2xl max-h-full">
				<!-- Container for the profile-engage template -->
				<div
					class=" feedback_div_1 feedback_div_2">
					<!-- Container for the profile-engage template -->
					<p class="emoji_happy">
						<img src="themes/custom/engage_theme/images/Profile/success.png" alt="Success Popup"/>
					</p>
					<div class="thanks_title">
						<p>{{'Profile Details Updated Successfully'|t}}</p>
					</div>

					<div
						class="modal-action justify-center gap-5 mb-5">
						<!-- Container for the profile-engage template -->
						<a href="my-account" class="btn btn-sm btn-warning w-52 h-12 text-white text-lg font-sans capitalize okay">Ok</a>

					</div>
					<!-- Container for the profile-engage template -->
				</div>
				<!-- Container for the profile-engage template -->
			</div>
			<!-- Container for the profile-engage template -->

		</div>

		{# Modal for Delete Family Member #}

		<!-- Hidden Modal -->


		<div id="popup-modal" tabindex="-1" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full bg-[#0000009c]">
			<div class="relative p-4 w-full max-w-xl max-h-full">
				<div class="relative bg-white rounded-lg shadow-sm">
					<button type="button" class="absolute top-3 end-2.5 text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center dark:hover:bg-gray-600 dark:hover:text-white" data-modal-hide="popup-modal">
						<svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 14 14">
							<path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
						</svg>
						<span class="sr-only">{{'Close modal'|t}}</span>
					</button>
					<input type="hidden" id="delete-nid" value="">
					<div class="p-4 md:p-5 text-center">
						<svg class="mx-auto mb-4 text-gray-400 w-12 h-12 dark:text-gray-200" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 20 20">
							<path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 11V6m0 8h.01M19 10a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
						</svg>
						<h3 class="font-bold text-2xl font-nevis mb-6">{{'Are you sure you want to delete your member?'|t}}</h3>
						<button data-modal-hide="popup-modal" type="button" class="engage-btn confirm-delete-btn text-white bg-[#ffcc00] focus:ring-4 focus:outline-none focus:ring-red-300 dark:focus:ring-red-800 font-medium rounded-lg text-sm inline-block items-center px-5 py-2.5 text-center">
							{{'Yes'|t}}
						</button>
						<button data-modal-hide="popup-modal" type="button" class="engage-cancel-btn py-2.5 px-5 ms-3 text-sm font-medium text-gray-900 focus:outline-none bg-white rounded-lg border border-gray-200 hover:bg-gray-100 focus:z-10 focus:ring-4 focus:ring-gray-100 dark:focus:ring-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:text-white dark:hover:bg-gray-700">{{'No'|t}}</button>
					</div>
				</div>
			</div>
		</div>

		<div id="remove-profile-picture-modal" tabindex="-1" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0  max-h-full bg-[#0000009c]">
			<div class="relative p-4 w-full max-w-xl max-h-full">
				<div class="relative bg-white rounded-lg shadow-sm">
					<input type="hidden" id="delete-nid" value="">
					<div class="md:p-5 text-center max-w-[640px] max-w-[640px] p-10">
						<h3 class="font-bold text-2xl font-nevis mb-6">{{'Are you sure you want to remove your Profile Picture?'|t}}</h3>
						<button data-modal-hide="remove-profile-picture-modal" engage-button="engage-button-modal" type="button" id="remove-btn" class="engage-btn w-[135px] text-white bg-[#ffcc00] focus:ring-4 focus:outline-none focus:ring-red-300 dark:focus:ring-red-800 font-medium rounded-lg text-sm inline-block items-center px-5 py-2.5 text-center">
							{{'Yes'|t}}
						</button>
						<button data-modal-hide="remove-profile-picture-modal" type="button" class="engage-cancel-btn w-[135px] py-2.5 px-5 ms-3 text-sm font-medium text-gray-900 focus:outline-none bg-white rounded-lg border border-gray-200 hover:bg-gray-100 focus:z-10 focus:ring-4 focus:ring-gray-100 dark:focus:ring-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:text-white dark:hover:bg-gray-700">{{'No'|t}}</button>
					</div>
				</div>
			</div>
		</div>
		{# Modal for Delete Account #}


	</div>
</div></div>
