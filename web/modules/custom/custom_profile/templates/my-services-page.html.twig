<div
	class="mx-auto max-w-screen-xl bg-white py-6 px-4">
	<!-- Header -->
	<div class="flex justify-between items-baseline gap-4 pt-20 flex-wrap md:flex-nowrap">
		<div>
			<a href="/my-account">
				<svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="currentColor" class="bi bi-arrow-left" viewbox="0 0 16 16">
					<path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
				</svg>
			</a>
		</div>
		<div class="text-center w-full md:w-auto">
			<h1 class="text-3xl sm:text-4xl md:text-5xl font-nevis sm:pb-4 md:pb-12">{{ 'Service Request/Complaints'|t }}</h1>
		</div>
		<div></div>
	</div>

	<div
		class="form-sec border-inherit	border-2 rounded-xl p-4 lg:p-10 bg-white mb-44 text-center lg:text-start xs:mb-20 s:mb-20">
		{# Search bar #}
		<form method="get" action="" class="mb-4 flex items-center gap-2">
			<input type="text" name="search" value="{{ search }}" placeholder="Search by Complaint ID, Type, or Status" class="px-4 py-2 border-2 border-[#cecece] rounded-md w-full sm:w-[300px] md:w-[400px]"/>
			<button type="submit" class="bg-yellow-500 text-white rounded-full px-6 py-2 hover:bg-yellow-600 transition">
				{{'Search'|t}}
			</button>
		</form>

		<div class="overflow-x-auto">
			<table class="w-full text-sm text-left text-gray-700">
				<thead class="text-xs text-gray-700 uppercase bg-gray-100">
					<tr class="bg-white border-b hover:bg-gray-50 font-nevis">
						<th scope="col" class="px-4 py-4 text-center">#</th>
						<th scope="col" class="px-4 py-4 text-center">{{'Complaint ID'|t}}</th>
						<th scope="col" class="px-4 py-4 text-center">{{'Request/Complaint Type'|t}}</th>
						<th scope="col" class="px-4 py-4 text-center">{{'Created date'|t}}</th>
						<th scope="col" class="px-4 py-4 text-center">{{'Remarks'|t}}</th>
						<th scope="col" class="px-4 py-4 text-center">{{'Status'|t}}</th>
						<th scope="col" class="px-4 py-4 text-center">{{'Action'|t}}</th>
					</tr>
				</thead>
				<tbody>
					{% for item in data.data %}
						<tr class="bg-white border-b hover:bg-gray-50">
							<td class="px-4 py-4">{{ loop.index + ((current_page - 1) * items_per_page) }}</td>
							<td class="px-4 py-4">{{ item.grievanceId }}</td>
							<td class="px-4 py-4">{{ item.incidentSubType }}</td>
							<td class="px-4 py-4">{{ item.receivedTime|date("d/m/Y, h:i:s a", "Asia/Kolkata") }}</td>
							<td class="px-4 py-4 truncate">{{ item.userRemarks }}</td>
							<td class="px-4 py-4 text-[#5A2525] font-bold text-center">{{ item.status }}</td>
							<td class="px-4 py-4 text-center">
								<a href="/request/{{ item.grievanceId }}?type={{ item.requestTypeId }}" class="hover:text-blue-600">
                                    <img src="/modules/custom/custom_profile/images/Profile/view.svg" alt="View" class="h-6 w-6 inline-block">
                                </a>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="7" class="px-4 py-4 text-center text-gray-500">No records found</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>

		{# Pagination #}
		<div class="flex justify-center mt-4 flex-wrap gap-1 font-nevis">
			{% set total_pages = (total_count / items_per_page)|round(0, 'ceil') %}
			{% set start_page = current_page - 1 > 0 ? current_page - 1 : 1 %}
			{% set end_page = start_page + 2 < total_pages ? start_page + 2 : total_pages %}
			{% set start_page = end_page - 2 > 0 ? end_page - 2 : 1 %}

			{% if current_page > 1 %}
				<a href="?page=1{% if search %}&search={{ search }}{% endif %}" class="px-3 py-1 rounded rounded-lg border bg-white hover:bg-gray-100 text-black">« First</a>
				<a href="?page={{ current_page - 1 }}{% if search %}&search={{ search }}{% endif %}" class="px-3 py-1 rounded rounded-lg border bg-white hover:bg-gray-100 text-black">‹ Prev</a>
			{% endif %}

			{% for i in start_page..end_page %}
				<a href="?page={{ i }}{% if search %}&search={{ search }}{% endif %}" class="px-3 py-1 rounded rounded-full border {{ i == current_page ? 'bg-yellow-400 text-black font-bold' : 'bg-white text-black hover:bg-gray-100' }}">
					{{ i }}
				</a>
			{% endfor %}

			{% if current_page < total_pages %}
				<a href="?page={{ current_page + 1 }}{% if search %}&search={{ search }}{% endif %}" class="px-3 py-1 rounded border bg-white hover:bg-gray-100 text-black">Next ›</a>
				<a href="?page={{ total_pages }}{% if search %}&search={{ search }}{% endif %}" class="px-3 py-1 rounded border bg-white hover:bg-gray-100 text-black">Last »</a>
			{% endif %}
		</div>
	</div>
</div>
