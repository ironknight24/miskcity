<div class="flex items-center space-x-3">
  <a id="font_resize-minus"
     href="#"
     aria-label="{{ labels.minus }}"
     class="resize-btn text-gray-700 hover:text-black font-bold transition">
    A-
  </a>

  <a id="font_resize-default"
     href="#"
     aria-label="{{ labels.default }}"
     class="resize-btn text-gray-700 hover:text-black font-bold transition active">
    A
  </a>

  <a id="font_resize-plus"
     href="#"
     aria-label="{{ labels.plus }}"
     class="resize-btn text-gray-700 hover:text-black font-bold transition">
    A+
  </a>
</div>
