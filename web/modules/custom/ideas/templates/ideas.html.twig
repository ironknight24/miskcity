<div class="mx-auto max-w-screen-xl py-2 px-4">
	<div class="flex justify-between items-baseline gap-4 py-10">
		<div>
			<a onclick="history.go(-1)" class="text-gray-600 hover:text-gray-800">
				<svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="currentColor" class="bi bi-arrow-left" viewbox="0 0 16 16">
					<path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"></path>
				</svg>
			</a>
		</div>
		<div class="text-center">
			<h1 class="text-3xl md:text-5xl font-nevis">Ideas</h1>
		</div>
		<div></div>
	</div>


	<!-- ✅ Ensure form is wrapped inside this div -->
	<div class="add-ideas-user border-[2px] border-inherit rounded-lg p-4 sm:p-6 md:p-8 lg:p-12 xl:p-16 bg-white" id="engage_form_input">
		<div id="ideas-flex" class="flex flex-col md:flex-row md:gap-8 gap-4">
			<div class="w-full md:w-1/2 font-nevis">
				{{ include('@engage_theme/components/form/field--floating-text.html.twig', {
                    				field: form.first_name
                				}) }}
			</div>
			<div class="w-full md:w-1/2 font-nevis">
				{{ include('@engage_theme/components/form/field--floating-text.html.twig', {
                    				field: form.author
                				}) }}
			</div>

		</div>
		<div class="mt-4 font-nevis">
			{{ include('@engage_theme/components/form/field--floating-text.html.twig', {
                    				field: form.category_idea
                				}) }}
		</div>
		<div>
			{{ form.idea_content }}
		</div>
		<div class="w-full md:w-1/2 mt-4">
			{{ form.upload_file }}
			{{ form.upload_file_hidden }}
		</div>
		<div class="mb-4 relative">
			<label class="label cursor-pointer justify-start gap-4 xs:gap-2 flex">
				{{ form.terms }}
				<span class="terms-conditions">I agree on
					<a href="https://www.trinitymobility.com/" target="_blank" class="text-blue-600 underline hover:text-blue-900">Terms and Conditions</a>
				</span>
			</label>
		</div>
		<div class="flex gap-2 mt-8 justify-center md:justify-start">
			{{ form.actions.submit }}
			{{ form.actions.reset }}
		</div>
	</div>
	{# </div> #}
	{{ form.form_src_id }}
	{{ form.form_build_id }}
	{{ form.form_token }}
	{{ form.form_id }}
</div>
