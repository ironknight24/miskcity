<div class="min-h-screen bg-cover bg-center flex items-center justify-center"
     style="background-image: url('/modules/custom/custom_profile/images/registeration-bg.png');">

  <div class="p-12 bg-white shadow-md rounded-lg max-w-md w-full mx-4 my-10">
    <h2 class="text-2xl font-semibold mb-6 text-center">Forgot Password</h2>

    <div class="mb-6">
      <p class="text-gray-600 text-sm text-center">
        Please enter the email address associated with your account.
        You will receive a link to reset your password.
      </p>
    </div>

    <div class="border-b border-gray-200 mb-6"></div>

    <form{{ attributes.addClass('space-y-5') }} method="post" action="{{ form['#action']|escape }}">

      {# Email Field with your floating component #}
      <div>
        {{ include('@engage_theme/components/form/field--floating-text.html.twig', {
          field: form.email,
        }) }}
      </div>

      {# Submit Button #}
      <div class="mt-4">
        {{ form.actions.submit }}
      </div>

      {# Hidden Fields #}
      {{ form|without('email', 'actions') }}

    </form>
  </div>
</div>
