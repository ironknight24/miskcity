<div class="min-h-screen bg-cover bg-center flex items-center justify-center" style="background-image: url('/modules/custom/custom_profile/images/registeration-bg.png');">
  <div class="p-12 bg-white shadow-md rounded-lg max-w-md w-full mx-4 my-10">
    <h2 class="text-2xl font-semibold mb-6">{{ 'Welcome'|t }}</h2>

    {% if form.password['#required'] %}
      <div class="mb-6">
        <p class="text-gray-600 text-sm">{{ 'Please enter your Email ID to Login'|t }}</p>
      </div>
    {% else %}
      <div class="mb-6">
        <p class="text-gray-600 text-sm">{{ 'Please enter your Email ID to Login / Register'|t }}</p>
      </div>
    {% endif %}

    <div class="border-b border-gray-200 mb-6"></div>

    {# Render the form with attributes #}
    <form{{ attributes.addClass('space-y-5') }} method="post" action="{{ form['#action']|escape }}">

      {# Email Field #}
      <div>
        {{ include('@engage_theme/components/form/field--floating-text.html.twig', {
          field: form.email,
        }) }}
      </div>

      {# Password Field (Shown only after email validated) #}
      {% if form.password['#required'] %}
        <div class="mt-2">
          {{ include('@engage_theme/components/form/field--floating-text.html.twig', {
            field: form.password,
          }) }}
        </div>

        {# Login button first so Enter key triggers login #}
        {% if form.login is defined %}
          <div class="mt-4">
            {{ form.login }}
          </div>
        {% endif %}

        {# Forgot Password second (so Enter doesn’t trigger it) #}
        {% if form.forgot_password is defined %}
          <div class="text-right text-sm mt-2">
            {{ form.forgot_password }}
          </div>
        {% endif %}
      {% else %}
        {# Initial Email Verification Submit #}
        <div class="mt-4">
          {{ form.check_email }}
        </div>
      {% endif %}

      {# Signup Link (optional) #}
      {% if form.signup_link is defined %}
        <div class="text-center">
          {{ form.signup_link }}
        </div>
      {% endif %}

      {# Render Hidden Fields (token, build id, etc.) #}
      {{ form|without('email', 'password', 'login', 'check_email', 'signup_link', 'forgot_password') }}

    </form>
  </div>
</div>