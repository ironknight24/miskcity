<div
	class="mx-auto max-w-screen-xl topbar bg-white py-10 px-4">
	<!-- Header -->
	<div class="flex sm:flex-row justify-between items-start sm:items-center gap-4 pt-2 pb-10">
		<div>
			{# <a
							href="/" class="text-gray-700 hover:text-yellow-600"> #}
			<a
				href="javascript:history.back()" class="text-gray-700 hover:text-yellow-600">
				<!-- Back Icon -->
				<svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="currentColor" class="bi bi-arrow-left" viewbox="0 0 16 16">
					<path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
				</svg>
			</a>
		</div>
		<div class="text-center flex-1">
			<h1 class="text-3xl sm:text-4xl md:text-5xl font-nevis">{{ 'Smart Services'|t }}</h1>
		</div>
	</div>

	<div class="flex flex-col md:flex-row gap-8">
		{% if siblings is not null %}
			<!-- Sidebar -->
			<aside class="w-full md:w-1/4 space-y-2">
				{% if parent_term %}
					<h2 class="text-lg font-semibold text-gray-700">{{ parent_term.label }}</h2>
				{% endif %}
				<ul class="space-y-1">
					{% for sibling in siblings %}
						<li>
							<a href="/services/{{ sibling.id() }}" class="block px-4 py-2 rounded {{ sibling.id() == current_term.id() ? 'bg-yellow-100 text-yellow-700 font-bold' : 'hover:bg-gray-100 text-gray-700' }}">
								{{ sibling.label() }}
							</a>
						</li>
					{% endfor %}
				</ul>
			</aside>
		{% endif %}

		<!-- Main Content -->
		<section class="w-full md:w-3/4">
			{% if terms %}
				<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 place-items-center">
					{% for term in terms %}
						<a href="/services/{{ term.id() }}" class="border-custom cursor-pointer flex items-center justify-center flex-col w-44 h-40 md:w-60 md:h-52 gap-5 md:gap-10 text-xl rounded-2xl md:rounded-3xl bg-white border border-transparent hover:border-yellow-500 hover:border-b-4 transition duration-300 p-4">
							{% if term.field_smart_service_image.0.entity.uri.value %}
								<img class="object-contain h-16 w-16 md:h-20 md:w-20" src="{{ file_url(term.field_smart_service_image.0.entity.uri.value|image_style('smart_service')) }}" alt="{{ term.label() }}">
							{% endif %}
							<h2 class="text-sm md:text-xl text-center text-gray-800 font-bold capitalize font-nevis">{{ term.label() }}</h2>
						</a>
					{% endfor %}
				</div>
			{% else %}
				<div class="text-gray-500 py-8 text-center">{{ 'No results found.'|t }}</div>
			{% endif %}
		</section>
	</div>
</div>
