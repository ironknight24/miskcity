<div class="relative w-full h-[400px] sm:h-[500px] md:h-[500px] overflow-hidden">
  {% if image_url %}
    <div
      class="absolute inset-0 bg-cover bg-center"
      style="background-image: url('{{ image_url }}');"
      role="img"
      aria-label="{{ image_alt }}">
    </div>

    {# Optional: Overlay to darken image for better text readability #}
    <div class="absolute inset-0 bg-black bg-opacity-50 z-0"></div>
  {% endif %}

  <div class="relative z-10 flex flex-col justify-center h-full px-12 sm:px-12 max-w-screen-xl mx-auto">
    {% if title %}
      <h2 class="text-2xl sm:text-4xl md:text-5xl font-bold text-white mb-4 font-nevis">
        {{ title }}
      </h2>
    {% endif %}

    {% if body %}
      <div class="text-sm sm:text-lg md:text-xl text-white max-w-2xl leading-relaxed">
        {{ body|raw }}
      </div>
    {% endif %}
  </div>
</div>
