<div class="mx-auto max-w-screen-xl topbar bg-white py-4 px-4 sm:px-6 lg:px-8">
  {% if label %}
    <h2{{ title_attributes.addClass('text-2xl md:text-4xl lg:text-5xl mb-4 lg:mb-6 font-nevis') }}>
      {{ label }}
    </h2>
  {% endif %}
  {% block content %}
    <div class="text-gray-600 text-base sm:text-lg font-semibold opacity-80 leading-relaxed mt-2 mb-6 font-nevis">
      {{ content.field_target_sub_heading[0]['#context'].value }}
    </div>

    <!-- Responsive grid: 1 on mobile, 2 on small, 3 on medium, 4 on large, 7 on extra-large -->
    <div class="each-targets grid grid-cols-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-7 gap-4 sm:gap-6 md:gap-8">
      {{ content.field_targets }}
    </div>
  {% endblock %}
</div>
