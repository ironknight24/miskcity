<div class="mx-auto max-w-screen-xl topbar bg-white py-6 px-4">
  {% if label %}
    <h2{{ title_attributes }} {{ attributes.addClass('text-center text-2xl md:text-5xl mb-8 lg:mt-12 lg:mb-4 font-nevis') }}>{{ label }}</h2>
  {% endif %}
    {% block content %}
        {{ (content) }}
    {% endblock %}
    <div class="flex justify-center mt-3">
        <a href="event-categories">
            <button class="bg-yellow-500 hover:bg-yellow-600 text-white font-semibold text-sm xs:text-xs px-6 py-3 xs:px-4 xs:py-2 rounded-md shadow transition duration-200 capitalize translateLabel" label-alias="la_see_more">
            See More
            </button>
        </a>
    </div>
</div>