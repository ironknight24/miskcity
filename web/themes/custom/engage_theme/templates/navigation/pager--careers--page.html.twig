{% if items %}
  <nav class="flex mt-10" role="navigation" aria-labelledby="{{ heading_id }}">
    <{{ pagination_heading_level }} id="{{ heading_id }}" class="sr-only">
      {{ 'Pagination'|t }}
    </{{ pagination_heading_level }}>
    <ul class="inline-flex items-center flex-wrap gap-2 text-sm font-medium">

      {# First page link #}
      {% if items.first %}
        <li>
          <a href="{{ items.first.href }}"
             title="{{ 'Go to first page'|t }}"
             class="py-[5px] px-[13px] font-nevis bg-white text-black border border-gray-300 rounded hover:bg-gray-100">
            {{ items.first.text|default('« First'|t) }}
          </a>
        </li>
      {% endif %}

      {# Previous page link #}
      {% if items.previous %}
        <li>
          <a href="{{ items.previous.href }}"
             title="{{ 'Go to previous page'|t }}"
             class="py-[5px] px-[13px] font-nevis bg-white text-black border border-gray-300 rounded hover:bg-gray-100">
            {{ items.previous.text|default('‹ Prev'|t) }}
          </a>
        </li>
      {% endif %}

      {# Ellipsis before #}
      {% if ellipses.previous %}
        <li class="text-gray-400 px-2">…</li>
      {% endif %}

      {# Page numbers #}
      {% for key, item in items.pages %}
        <li>
          {% if current == key %}
            <span class="py-[5px] px-[13px] font-nevis bg-yellow-500 text-white rounded">
              {{ key }}
            </span>
          {% else %}
            <a href="{{ item.href }}"
               title="{{ 'Go to page @key'|t({'@key': key}) }}"
               class="py-[5px] px-[13px] font-nevis bg-white text-black border border-gray-300 rounded hover:bg-gray-100">
              {{ key }}
            </a>
          {% endif %}
        </li>
      {% endfor %}

      {# Ellipsis after #}
      {% if ellipses.next %}
        <li class="text-gray-400 px-2">…</li>
      {% endif %}

      {# Next page link #}
      {% if items.next %}
        <li>
          <a href="{{ items.next.href }}"
             title="{{ 'Go to next page'|t }}"
             class="py-[5px] px-[13px] font-nevis bg-white text-black border border-gray-300 rounded hover:bg-gray-100">
            {{ items.next.text|default('Next ›'|t) }}
          </a>
        </li>
      {% endif %}

      {# Last page link #}
      {% if items.last %}
        <li>
          <a href="{{ items.last.href }}"
             title="{{ 'Go to last page'|t }}"
             class="py-[5px] px-[13px] font-nevis bg-white text-black border border-gray-300 rounded hover:bg-gray-100">
            {{ items.last.text|default('Last »'|t) }}
          </a>
        </li>
      {% endif %}

    </ul>
  </nav>
{% endif %}
