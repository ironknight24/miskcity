<article{{attributes}}>
	<div
		class="mx-auto max-w-screen-xl bg-white py-6 px-4 sm:px-6 lg:px-8">

		<!-- Header -->
		<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 pt-10">
			<a href="/career" class="text-gray-600 hover:text-black">
				<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 sm:w-8 sm:h-8" fill="currentColor" viewbox="0 0 16 16">
					<path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
				</svg>
			</a>

			<h1 class="text-3xl sm:text-4xl lg:text-5xl font-nevis text-center sm:text-left">
				{{ 'Apply for'|t }}
				{{ node.title.value }}
			</h1>

			<div class="hidden sm:block w-6"></div>
		</div>

		<!-- Job Details -->
		<div class="mt-10 space-y-6">
			<div class="grid grid-cols-1 sm:grid-cols-12 gap-2 items-start">
				<p class="sm:col-span-3 font-nevis text-gray-800">{{ content.field_qualification['#title'] }}</p>
				<span class="sm:col-span-1 text-gray-600">:</span>
				<p class="sm:col-span-8 text-gray-700 font-sans">{{ content.field_qualification[0]['#context'].value }}</p>
			</div>

			<div class="grid grid-cols-1 sm:grid-cols-12 gap-2 items-start">
				<p class="sm:col-span-3 font-nevis text-gray-800">{{ content.field_experience['#title'] }}</p>
				<span class="sm:col-span-1 text-gray-600">:</span>
				<p class="sm:col-span-8 text-gray-700 font-sans">{{ content.field_experience[0]['#context'].value }}</p>
			</div>

			<div class="grid grid-cols-1 sm:grid-cols-12 gap-2 items-start">
				<p class="sm:col-span-3 font-nevis text-gray-800">{{ content.field_job_location['#title'] }}</p>
				<span class="sm:col-span-1 text-gray-600">:</span>
				<p class="sm:col-span-8 text-gray-700 font-sans">{{ content.field_job_location[0]['#context'].value }}</p>
			</div>
		</div>

		<hr
		class="my-8 border-gray-300">

		<!-- Job Description -->
		<div class="mb-8">
			<h2 class="text-2xl text-gray-800 font-nevis mb-2">{{ content.field_job_description['#title'] }}</h2>
			<div class="prose max-w-none text-gray-700">
				{{ content.field_job_description[0]['#text']|raw }}
			</div>
		</div>

		<!-- Responsibilities -->
		<div class="mb-10">
			<h2 class="text-2xl text-gray-800 font-nevis mb-2">{{ content.field_responsibilities['#title'] }}</h2>
			<div class="prose max-w-none text-gray-700">
				{{ content.field_responsibilities[0]['#text']|raw }}
			</div>
		</div>

		{# <div class="career-apply-form bg-gray-50 p-6 rounded-xl"> #}
			{# <h2 class="text-2xl font-bold mb-4">{{ 'Apply for this Job'|t }}</h2> #}
			{{ drupal_form('Drupal\\career_application\\Form\\CareerApplyForm', node.id) }}
		{# </div> #}
	</div>
</article>
