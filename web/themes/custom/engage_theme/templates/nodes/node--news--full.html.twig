<article{{ attributes }}>
  <div class="mx-auto max-w-screen-xl bg-white py-6 px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 pt-10">
      <div>
        <a href="/" class="text-gray-700 hover:text-yellow-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
          </svg>
        </a>
      </div>
      <div class="text-center flex-1">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-nevis">{{ 'News & Media'|t }}</h1>
      </div>
    </div>

    <!-- News Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mt-10">

      <!-- News Content -->
      <div class="lg:col-span-8">
        <div class="card news-page">
          <div class="relative">
            {% set uri = content.field_news_poster[0]['#item'].entity.uri.value %}
            <img 
              src="{{ file_url(uri) }}" 
              alt="{{ node.title.value }}" 
              class="w-full h-auto rounded-lg object-cover" 
              loading="lazy"
            >
          </div>
          <div class="card-body px-0 pt-6">
            <h2 class="text-2xl sm:text-3xl font-nevis text-dark">{{ node.title.value }}</h2>
            <div class="text-base sm:text-lg font-sans font-light text-[#333333] my-3">
              <time datetime="00Z">{{ content.field_news_date[0]['#text'] }}</time>
              {{ 'by'|t }}
              <span class="font-bold">{{ content.field_news_author[0]['#context'].value }}</span>
            </div>
            <div class="card-desc details_desc my-4 text-base sm:text-lg">
              {{ content.field_news_body }}
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-4 space-y-10">

        <!-- About Author -->
        <div class="pt-8 pb-6 px-6 bg-[#f2f2f2] rounded-2xl">
          <h2 class="pb-5 text-xl sm:text-2xl font-nevis">{{ 'About Author'|t }}</h2>
          <div class="card">
            <div class="flex justify-center mb-4">
              {% set uri1 = content.field_news_author_image_pic[0]['#item'].entity.uri.value %}
              <img 
                src="{{ file_url(uri1) }}" 
                alt="{{ node.title.value }}" 
                class="w-24 h-24 rounded-full object-cover" 
                loading="lazy"
              >
            </div>
            <div class="card-body p-0 text-center">
              <div class="font-sans font-normal text-[#333333] my-3">
                {{ content.field_about_news_author_descript[0]['#context'].value }}
              </div>
            </div>
          </div>
        </div>

        <!-- Latest Posts -->
        <div class="pt-6 pb-6 px-6 bg-[#f2f2f2] rounded-2xl">
          <h2 class="pb-5 text-xl sm:text-2xl font-nevis">{{ 'Latest Posts'|t }}</h2>
          {{ drupal_view('news', 'latest_news') }}
        </div>

      </div> <!-- end sidebar -->

    </div> <!-- end grid -->
	<div class="border-t border-[#dedede] border-solid dottedBorder my-6"></div>

    <div class="news-belowview pt-8 pb-5">
		<h1 class="pb-8 text-4xl font-nevis text-[#000000]">{{ 'Trending Posts'|t }}</h1>
		{{ drupal_view('news', 'trending_news') }}
	</div>

  </div>
</article>
