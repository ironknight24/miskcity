<article{{ attributes.addClass('mx-auto max-w-screen-xl topbar bg-white py-2 px-4') }}>

    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 pt-10">
      <div>
        <a href="/" class="text-gray-700 hover:text-yellow-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
          </svg>
        </a>
      </div>
      <div class="text-center flex-1">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-nevis">{{ node.title.value }}</h1>
      </div>
    </div>

  <div class="content mt-10 mb-16 px-4 sm:px-6 lg:px-8">
    {{ content }}
  </div>

</article>