																				<p class="font-semibold text-gray-800 truncate">{{ user.display_name }}</p>
																				<p class="text-sm text-gray-500 break-words whitespace-normal">{{ user.mail }}</p>
																			</div>
																		</div>
																	</div>
										
																	<!-- Links -->
																	<div class="px-4 py-2 space-y-1">
																		<a href="/my-account" class="block py-1 text-gray-800 hover:text-yellow-500">{{ 'My Profile'|t }}</a>
																		<a href="/service-request" class="block py-1 text-gray-800 hover:text-yellow-500">{{ 'My Requests'|t }}</a>
																		<a href="/survey" class="block py-1 text-gray-800 hover:text-yellow-500">{{ 'Survey'|t }}</a>
																	</div>
										
																	<!-- Logout -->
																	<div class="border-t px-4 py-2">
																		<a href="/logout" class="flex items-center gap-2 text-gray-800 hover:text-red-600">
