																				<path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h6a2 2 0 012 2v1"/>
																			</svg>
																			<span>{{ 'Log Out'|t }}</span>
																		</a>
																	</div>
																</div>
															</div> #}
					<div class="candy_box_strat candy_box_strat_web relative flex justify-center items-center gap-5">

						{# {{ drupal_block('notification_block')}} #}
						{# Services / Candy Box menu #}
							<div class="relative" id="candy-wrapper"> <button id="candy-button" class="cursor-pointer list-none">
								<img class="w-6 inline" src="/themes/custom/engage_theme/images/Engage/candy_box.png" alt="Menu"/>
							</button>

							<div id="candy-menu" class="absolute z-50 top-full left-1/2 -translate-x-1/2 mt-4 w-80 rounded-xl bg-white shadow-lg ring-1 ring-black ring-opacity-5 hidden">
								<div class="absolute -top-2 left-1/2 -translate-x-1/2 w-0 h-0 border-l-8 border-r-8 border-b-8 border-l-transparent border-r-transparent border-b-white"></div>
								<div class="overflow-y-auto max-h-96 p-4">
									<div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
										{{ drupal_menu('candy-menu-details') }}
									</div>
								</div>
							</div>
						</div>

					</div>

					{{ drupal_block('logged_in_details') }}
				{% else %}
					<a class="bg-yellow-500 text-white font-nevis rounded-full px-6 py-2 hover:bg-yellow-600 transition" href="/user-login">
						{{ 'Login/Sign up'|t }}
					</a>
				{% endif %}
			</div>

			<button id="menu-toggle" class="md:hidden text-white focus:outline-none ml-auto" aria-label="Toggle menu">
				<svg class="w-8 h-8" fill="none" stroke="currentColor" viewbox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
				</svg>
			</button>
		</div>

		<!-- Mobile Slide-out Menu (Right Tray) -->
		<div id="mobile-menu" class="fixed top-0 right-0 h-full w-64 bg-white text-black shadow-lg transform translate-x-full transition-transform duration-300 ease-in-out z-40 md:hidden">
			<div class="flex justify-between items-center p-4 border-b border-gray-700">
				<span class="text-lg font-bold">{{ 'CitizenPortal'|t }}</span>
				<button id="menu-close" aria-label="Close menu">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewbox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
					</svg>
				</button>
			</div>
			<nav class="p-4 space-y-4">
				{{ drupal_menu('main') }}
			</nav>
		</div>

		<!-- Optional: Backdrop -->
		<div id="backdrop" class="fixed inset-0 bg-black bg-opacity-50 hidden z-30 md:hidden"></div>
	</header>
	{# {{ page.primary_menu }} #}
	{{ page.highlighted }}
	{{ page.help }}
	<div class="">
		{% if page.sidebar %}
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
				<main class="lg:col-span-8">
					{{ page.content }}
				</main>
				<aside class="lg:col-span-4">
					{{ page.sidebar }}
				</aside>
			</div>
		{% else %}
			<div>
				{{ page.content }}
			</div>
		{% endif %}
	</div>

	{# {% if page.footer %} #}
	<footer class="page-footer bg-black px-4 py-8 sm:px-6 lg:px-10">
		<div
			class="mx-auto max-w-screen-xl pb-10">
			<!-- Top row: logo or other footer blocks -->
			<div class="flex flex-col sm:flex-row justify-between items-center sm:items-start gap-6 pb-10">
				{{ page.footer }}
			{# Optional block like user_visit_count_block #}
				{# {{ drupal_block('user_visit_count_block') }} #}
			</div>

			<!-- Footer main sections -->
			<div class="footer grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12">
				{% if page.footer_first %}
					<div class="col-span-12 lg:col-span-4 leading-8 text-[#fdfcfa] opacity-70">
						{{ page.footer_first }}
					</div>
				{% endif %}

				{% if page.footer_second %}
					<div class="col-span-6 sm:col-span-1 lg:col-span-2 ps-2 sm:ps-6 text-[#fdfcfa] opacity-70">
						{{ page.footer_second }}
					</div>
				{% endif %}

				{% if page.footer_third %}
					<div class="col-span-6 sm:col-span-1 lg:col-span-2 ps-2 sm:ps-6 text-[#fdfcfa] opacity-70">
						{{ page.footer_third }}
					</div>
				{% endif %}

				{% if page.footer_fourth %}
					<div class="col-span-12 lg:col-span-4 ps-2 sm:ps-8 text-[#fdfcfa] opacity-70">
						{{ page.footer_fourth }}
					</div>
				{% endif %}
			</div>
		</div>
		<div class="h-px opacity-80 border-t border-white bg-transparent box-border mx-auto max-w-screen-xl"></div>
		<div
			class="flex items-center justify-between pt-6 font-sans text-white mx-auto max-w-screen-xl">

			<!-- Invisible element to balance right-aligned version -->
			<div class="opacity-0">V3.2.0</div>

			<!-- Centered copyright -->
			<div class="text-center opacity-70">
				{{ 'Copyright ©'|t }}
				{{ "now"|date("Y") }}
				{{ ' - All Rights Reserved'|t }}
			</div>

			<!-- Right-aligned version -->
			<div class="text-sm text-gray-300">
				{{ 'V3.2.0'|t }}
			</div>

		</div>
	</footer>

{% endif %}
