<div data-drupal-messages class="space-y-4">
  {% for type, messages in message_list %}
    {% set wrapper_classes = {
      'status': 'bg-green-50 border border-green-200 text-green-800 rounded-md p-4',
      'warning': 'bg-yellow-50 border border-yellow-200 text-yellow-800 rounded-md p-4',
      'error': 'bg-red-50 border border-red-200 text-red-800 rounded-md p-4'
    } %}

    <div role="contentinfo"
         aria-label="{{ status_headings[type] }}"
         class="{{ wrapper_classes[type] ?? 'bg-gray-50 border border-gray-200 text-gray-800 rounded-md p-4' }}"
         {{ attributes|without('role', 'aria-label') }}>

      {% if type == 'error' %}
        <div role="alert">
      {% endif %}

      {% if status_headings[type] %}
        <h2 class="sr-only">{{ status_headings[type] }}</h2>
      {% endif %}

      {% if messages|length > 1 %}
        <ul class="list-disc pl-5 space-y-1">
          {% for message in messages %}
            <li>{{ message }}</li>
          {% endfor %}
        </ul>
      {% else %}
        <p>{{ messages|first }}</p>
      {% endif %}

      {% if type == 'error' %}
        </div>
      {% endif %}
    </div>
  {% endfor %}
</div>
