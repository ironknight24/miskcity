<div class="card bg-white border border-gray-200 rounded-2xl shadow-sm transition hover:shadow-md h-full flex flex-col justify-between">
  <div class="career-list p-6 sm:p-4 flex-grow">
    
    <h2 class="card-title text-2xl sm:text-xl font-nevis mb-4">
      {{ row._entity.title.0.value }}
    </h2>

    <div class="card-desc text-base font-sans text-gray-700 mb-6">
      {{ row._entity.field_job_description.0.value|striptags|slice(0, 240) ~ (row._entity.field_job_description.0.value|striptags|length > 240 ? '...' : '') | raw }}
    </div>

    <div class="card-actions mt-auto">
      <span class="btn subscription_btn bg-yellow-500 hover:bg-yellow-600 text-white text-base  font-bold px-5 py-2 rounded-xl transition duration-200 w-full sm:w-auto text-center">
        {{ fields.view_node.content }}
      </span>
    </div>

  </div>
</div>
