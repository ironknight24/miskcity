<div class="card flex flex-col sm:flex-row gap-4 items-start">  
  <!-- Image -->
  {# <div class="flex-shrink-0 w-full sm:w-1/4 md:w-1/5"> #}
    {{ fields.field_news_poster.content }}
  {# </div> #}

  <!-- Text and Button -->
  <div class="flex flex-col justify-between w-full sm:w-3/4 md:w-4/5">
    
    <!-- Title -->
    <h2 class="text-xl text-gray-800 mb-2 font-nevis">
      {{ fields.title.content }}
    </h2>

    <!-- Summary -->
    <div class="text-gray-700 text-base leading-relaxed mb-4">
      <p>{{ (row._entity.field_news_body.0.value|striptags|slice(0, 242)) }}</p>
    </div>

    <!-- Read More Button -->
    <div>
      {% set read_more_link = fields.view_node.content|render %}
      {% if read_more_link|render is not empty %}
        {{ read_more_link|replace({
          '<a ': '<a class="inline-block bg-yellow-400 hover:bg-yellow-500 text-white font-bold py-2 px-6 rounded-md transition" '
        })|raw }}
      {% endif %}
    </div>
  </div>
</div>

