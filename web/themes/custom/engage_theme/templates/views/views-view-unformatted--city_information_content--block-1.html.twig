{# First card in its own wrapper #}
{# {% if rows|length > 0 %}
  <div class="mx-auto max-w-screen-xl topbar bg-white py-2 px-4">
    <div id="{{ rows[0].content['#row']._entity.nid.0.value }}"
         class="flex flex-row justify-between gap-10 s:flex-col xs:flex-col max-w-7xl w-full">
      
      <div class="basis-2/4">
        <h2 class="md:text-5xl text-2xl font-bold 2xl:mb-10 mb-3 text-capitalize minlines font-nevis">
          {{ rows[0].content['#row']._entity.field_description_title.0.value }}
        </h2>
        <div class="text-gray83 text-opacity-100 text-justify font-500 xl:text-lg text-sm md:text-base leading-6 md:leading-7 font-['Open_Sans'] xl:leading-8 the-vidhana-soudha minlines">
          {{ rows[0].content['#row']._entity.field_city_information_body.0.value|raw }}
        </div>
      </div>

      <div class="max-w-full lg:max-w-[50%] max-h-[520px] rounded">
        <img class="object-contain w-full"
             src="{{ file_url(rows[0].content['#row']._entity.field_description_image.0.entity.uri.value|image_style('city_information_view')) }}"
             alt="{{ rows[0].content['#row']._entity.field_description_image.0.alt }}" width="100%"
             height="100%">
      </div>

    </div>
  </div>
{% endif %} #}

{# Grid of remaining cards #}
{# {% if rows|length > 1 %}
  <div class="mx-auto max-w-screen-xl topbar bg-white py-2 px-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 py-6">
      {% for key, row in rows %}
        {% if key > 0 %}
          <div id="{{ row.content['#row']._entity.nid.0.value }}">
            <div class="rounded">
              <img class="object-contain w-full md:h-64"
                  src="{{ file_url(row.content['#row']._entity.field_description_image.0.entity.uri.value|image_style('city_information_card')) }}"
                  alt="{{ row.content['#row']._entity.field_description_image.0.alt }}" height="100%"
                  width="100%">
            </div>
            <div class="xl:pt-6 pt-1">
              <h2 class="minlines text-xl md:text-3xl font-bold my-3 md:my-0 md:mb-3 text-capitalize font-nevis">
                {{ row.content['#row']._entity.title.0.value }}
              </h2>
              <div class="minlines text-gray83 text-opacity-100 text-justify font-500 xl:text-lg text-sm md:text-base leading-6 md:leading-7 font-['Open_Sans'] xl:leading-8 the-vidhana-soudha">
                {{ row.content['#row']._entity.field_city_information_body.0.value|striptags|replace({'&nbsp;': ' '})|trim|slice(0, 270) ~ '...' }}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
{% endif %} #}
{# First card section - full width on mobile/tablet, side-by-side on lg+ #}
{% if rows|length > 0 %}
		<div class="mx-auto max-w-screen-xl bg-white py-6 px-4 sm:px-6 lg:px-8"> <div id="{{ rows[0].content['#row']._entity.nid.0.value }}" class="flex flex-col lg:flex-row items-center gap-8">

			<div class="w-full lg:w-1/2">
				<h2 class="text-2xl md:text-4xl mb-4 text-capitalize font-nevis">
					{{ rows[0].content['#row']._entity.field_description_title.0.value }}
				</h2>
				<div class="text-gray83 text-opacity-100 text-justify font-500 xl:text-lg text-sm md:text-base leading-6 md:leading-7 font-sans xl:leading-8 minlines">
					{{ rows[0].content['#row']._entity.field_city_information_body.0.value|raw }}
				</div>
			</div>

			<div class="w-full lg:w-1/2 max-h-[520px] rounded overflow-hidden">
				<img class="object-cover w-full h-auto" src="{{ file_url(rows[0].content['#row']._entity.field_description_image.0.entity.uri.value|image_style('city_information_view')) }}" alt="{{ rows[0].content['#row']._entity.field_description_image.0.alt }}">
			</div>

		</div>
	</div>
{% endif %}

{# Remaining grid of cards - responsive 1/2/3 columns #}
{% if rows|length > 1 %}
	<div class="mx-auto max-w-screen-xl bg-white py-6 px-4 sm:px-6 lg:px-8">
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
			{% for key, row in rows %}
				{% if key > 0 %}
					<div id="{{ row.content['#row']._entity.nid.0.value }}" class="bg-white rounded">
						<div class="rounded overflow-hidden">
							<img class="object-cover w-full h-48 md:h-64" src="{{ file_url(row.content['#row']._entity.field_description_image.0.entity.uri.value|image_style('city_information_card')) }}" alt="{{ row.content['#row']._entity.field_description_image.0.alt }}">
						</div>
						<div class="pt-4">
							<h2 class="text-lg sm:text-xl md:text-2xl mb-2 text-capitalize font-nevis">
								{{ row.content['#row']._entity.title.0.value }}
							</h2>
							<div class="minlines text-gray83 text-opacity-100 text-justify font-500 xl:text-lg text-sm md:text-base leading-6 md:leading-7 font-sans xl:leading-8">
								{{ row.content['#row']._entity.field_city_information_body.0.value|striptags|replace({'&nbsp;': ' '})|trim|slice(0, 270) ~ '...' }}
							</div>
						</div>
					</div>
				{% endif %}
			{% endfor %}
		</div>
	</div>
{% endif %}
