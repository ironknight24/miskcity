{% set langcode = current_langcode %}

<div class="flex gap-6 overflow-x-auto sm:overflow-x-visible sm:flex-wrap sm:justify-center sm:gap-8 md:gap-20 snap-x snap-mandatory no-scrollbar mx-2 sm:mx-0">
  {% for row in rows %}
    {% set raw_entity = row.content['#row']._entity %}
    {% set entity = raw_entity.hasTranslation(langcode) ? raw_entity.getTranslation(langcode) : raw_entity %}

    <a href="#{{ entity.nid.0.value }}"
       onclick="document.getElementById('{{ entity.nid.0.value }}').scrollIntoView({ behavior: 'smooth' }); return false;"
       class="flex-shrink-0 border-custom cursor-pointer flex items-center justify-center flex-col w-44 h-40 xs:w-44 xs:h-40 s:w-44 s:h-40 md:w-60 md:h-52 gap-5 md:gap-10 text-xl rounded-2xl md:rounded-3xl bg-white border border-transparent hover:border-yellow-500 hover:border-b-4 transition duration-300 p-4 snap-start">

      <img class="object-contain h-16 w-16 md:h-20 md:w-20"
           src="{{ file_url(entity.field_city_information_image.0.entity.uri.value|image_style('city_information')) }}"
           alt="{{ entity.field_city_information_image.0.alt }}"
           height="64" width="64">

      <h2 class="text-sm md:text-xl text-center text-gray-800 capitalize font-nevis">
        {{ entity.field_description_title.0.value }}
      </h2>
    </a>
  {% endfor %}
</div>