<article{{attributes.addClass('text-center','group')}}>
	{{ title_prefix }}
	{{ title_suffix }}

	{# SAFE LINK HANDLING (no more route errors) #}
	{% set link_item = paragraph.field_link is not empty ? paragraph.field_link.get(0) : null %}
	{% set service_url = link_item ? link_item.getUrl().toString() : null %}

	{# GET ICON FILE URL #}
	{% set icon_src = content.field_icon['#items'] is not empty
    ? file_url(content.field_icon['#items'].0.entity.field_media_image.entity.uri.value)
    : null
  %}

	{% if service_url %}
		<a href="{{ service_url }}" class="block">
		{% else %}
			<div class="block cursor-default">
			{% endif %}

			<!-- Circle -->
			<div class="w-20 h-20 mx-auto rounded-full bg-slate-100 flex items-center justify-center mb-3 transition duration-300 group-hover:bg-misk-brand">

				{% if icon_src %}
					<!-- Mask Icon -->
					<span class="inline-block w-10 h-10 bg-misk-brand transition duration-300 group-hover:bg-white" style="
						            -webkit-mask-image: url('{{ icon_src|e('css') }}');
						            mask-image: url('{{ icon_src|e('css') }}');
						            -webkit-mask-size: contain;
						            mask-size: contain;
						            -webkit-mask-position: center;
						            mask-position: center;
						            -webkit-mask-repeat: no-repeat;
						            mask-repeat: no-repeat;
						          "></span>
				{% endif %}

			</div>

			<!-- Title -->
			<h3 class="text-sm font-medium text-misk-brand">
				{{ content.field_title }}
			</h3>

			{% if service_url %}
			</a>
	{% else %}
		</div>
	{% endif %}

</article>
